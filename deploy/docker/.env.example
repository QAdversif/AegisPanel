# SPDX-License-Identifier: AGPL-3.0-or-later
#
# Aegis local dev environment — example secrets.
# Copy this file to `deploy/docker/.env` and fill in real values.

# ----- Aegis panel ---------------------------------------------------------

AEGIS_ENV=development
AEGIS_HTTP_ADDR=:8080
AEGIS_SHUTDOWN_TIMEOUT=30s
AEGIS_GIT_COMMIT=dev
AEGIS_BUILD_TIME=

# 32+ char random secret for signing access tokens.
# Generate with: openssl rand -hex 32
AEGIS_JWT_SECRET=replace-me-with-openssl-rand-hex-32

# SOPS-encrypted file path for sensitive per-node / per-user secrets.
AEGIS_SECRETS_BACKEND=sops
AEGIS_SECRETS_FILE=/run/aegis/secrets.enc.yaml

# Auto-generated on first boot if empty. Used to derive
# /s3cr3t-p4n3l-<hex> and /s3cr3t-sub-<hex> paths.
AEGIS_PATH_SECRET=

# Caddy admin API URL (used to reload Caddyfile at runtime).
AEGIS_CADDY_ADMIN_URL=http://caddy:2019

# Decoy-site storage root (defaults to /var/www/decoy on panel host).
AEGIS_DECOY_ROOT=/var/www/decoy

# ----- PostgreSQL ----------------------------------------------------------

POSTGRES_USER=aegis
POSTGRES_PASSWORD=replace-me-postgres
POSTGRES_DB=aegis
AEGIS_POSTGRES_DSN=postgres://aegis:replace-me-postgres@postgres:5432/aegis?sslmode=disable

# ----- Redis ---------------------------------------------------------------

AEGIS_REDIS_ADDR=redis:6379
AEGIS_REDIS_DB=0

# ----- NATS ----------------------------------------------------------------

AEGIS_NATS_URL=nats://nats:4222

# ----- ClickHouse ----------------------------------------------------------

AEGIS_CLICKHOUSE_DSN=clickhouse://aegis:replace-me-clickhouse@clickhouse:9000/aegis

# ----- Caddy (panel side) -------------------------------------------------

# Public domain the panel will be served from in dev. Caddy issues
# a self-signed certificate for *.aegis.local.
AEGIS_PANEL_DOMAIN=panel.aegis.local
AEGIS_PANEL_EMAIL=admin@aegis.local

# Cloudflare DNS-01 token (optional). Leave empty in dev to use the
# internal ACME http-01 challenge.
AEGIS_CLOUDFLARE_API_TOKEN=

# ----- Observability -------------------------------------------------------

# Path under which the panel exposes Prometheus metrics.
AEGIS_METRICS_PATH=/metrics
