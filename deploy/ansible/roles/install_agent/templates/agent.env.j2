;
; Environment file for the Aegis agent on a node.
; Filled in by the install_agent Ansible role.
;
; The agent reads `AEGIS_AGENT_BEARER` from the
; environment on start; the bearer is generated
; by the panel's `internal/bootstrap/secrets.go`
; and pasted in here per-host. Do NOT commit this
; file to source control — it carries the
; per-node secret. The systemd unit
; `aegis-agent.service` includes
; `EnvironmentFile=/etc/aegis/agent.env` so the
; agent picks it up automatically.

AEGIS_AGENT_NODE_NAME={{ aegis_node_name }}
AEGIS_AGENT_PANEL_URL={{ aegis_panel_url }}
AEGIS_AGENT_LISTEN_ADDR={{ aegis_agent_listen_addr }}
AEGIS_AGENT_BEARER={{ aegis_agent_bearer }}
AEGIS_AGENT_LOG_LEVEL={{ aegis_agent_log_level }}
