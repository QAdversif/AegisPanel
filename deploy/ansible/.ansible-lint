---
# Aegis ansible-lint baseline.
# We are not enforcing strict FQCN / name conventions in Phase 0 — most
# playbooks are still placeholders. Tighten per-file as modules land.
exclude_paths:
  - .cache/
  - .github/
  - deploy/ansible/inventories/

skip_list:
  - role-name        # role dirs use kebab-case
  - schema[meta]     # roles/*/meta/main.yml not yet populated
  - fqcn[action-core]
  - fqcn[action-plugin]
  - name[play]
  - name[role]
  - name[task]       # handler/task names use lowercase (role-internal)
  - name[casing]     # same: handler/task names start with lowercase by convention
  - var-naming[no-reserved]
  - var-naming[no-role-prefix]  # defaults shared across multiple roles (aegis_* prefix is intentional)
  - var-naming[pattern]        # variables use aegis_* / role_ prefix, not enforced
  - syntax-check[false]
  - yaml[octal-values]

use_default_rules: true
