# --- Aegis monorepo .gitignore ---

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.iml
.DS_Store?

# Secrets & local config
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
secrets/
config/local.*

# --- Go ---
backend/bin/
backend/dist/
backend/coverage/
backend/*.out
backend/vendor/
backend/.golangci-cache/
*.test
*.prof

# --- Vue / Node / pnpm ---
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/.cache/
frontend/.nuxt/
docs/node_modules/
docs/.vuepress/.cache/
docs/.vuepress/.temp/
docs/.vuepress/dist/
.pnpm-store/
node_modules/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Ansible ---
deploy/ansible/.vault_pass
deploy/ansible/*.retry
deploy/ansible/roles/*/.vault_pass
*.pyc
__pycache__/

# --- Docker / dev volumes ---
deploy/docker/.volumes/
deploy/docker/postgres-data/
deploy/docker/redis-data/
deploy/docker/nats-data/
deploy/docker/clickhouse-data/
deploy/docker/caddy-data/

# --- Caddy ---
deploy/caddy/*.bak
deploy/caddy/acme/

# --- Build / coverage artefacts ---
*.tar.gz
*.zip
dist/
build/
out/
coverage/
.nyc_output/

# --- Test artefacts ---
playwright-report/
test-results/
.vitest-cache/

# --- Local node / cert storage (real deployments) ---
deploy/caddy/data/
deploy/caddy/config/
deploy/caddy/letsencrypt/

# --- Editor workspace ---
*.code-workspace
.idea/

# --- Generated docs (when built) ---
docs/.vuepress/dist/
docs/.vuepress/.cache/

# --- Local debug logs ---
*.log
logs/
*.pid
*.seed
*.pid.lock

# --- Backup files ---
*.bak
*.swp
*.tmp
*.orig
*.rej

# --- Generated keys / certs (sandbox only) ---
*.csr
*.crt
*.key
*.p12
*.pfx
