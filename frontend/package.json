{
  "name": "aegis-ui",
  "version": "0.0.0-dev",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "description": "Aegis admin UI — Vue 3 + TypeScript + Vite",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,json,css,scss,md}\"",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/vue-table": "^8.21.3",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^11.3.0",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^2.2.6",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.6.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.13",
    "vue-i18n": "^10.0.5",
    "vue-router": "^4.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "10.5",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^25.0.1",
    "postcss": "8.5",
    "prettier": "^3.4.1",
    "sass": "^1.81.0",
    "tailwindcss": "3.4",
    "tailwindcss-animate": "1.0",
    "typescript": "~5.6.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6",
    "vue-tsc": "^2.1.10"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.0"
    }
  }
}
